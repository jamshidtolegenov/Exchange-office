# ─── Frontend Environment Variables ──────────────────────────────────────────
# React env vars MUST start with REACT_APP_

# API base URL
# For LOCAL development: leave empty (uses "proxy" in package.json → localhost:4000)
# For PRODUCTION (Vercel): set to your Render backend URL
REACT_APP_API_URL=https://exchange-office-db-ttza.onrender.com/api
